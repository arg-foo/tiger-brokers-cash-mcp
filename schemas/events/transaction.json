{
  "$id": "tiger-events-transaction",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Full Redis stream event for transaction (execution/fill) changes.",
  "properties": {
    "account": {
      "description": "Tiger Brokers account identifier.",
      "title": "Account",
      "type": "string"
    },
    "timestamp": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Event timestamp from Tiger Brokers (epoch milliseconds as string).",
      "title": "Timestamp"
    },
    "received_at": {
      "description": "ISO 8601 timestamp when the event was received by the subscriber.",
      "format": "date-time",
      "title": "Received At",
      "type": "string"
    },
    "payload": {
      "contentMediaType": "application/json",
      "contentSchema": {
        "description": "Payload for order transaction (execution/fill) events.\n\nFields mirror the ``OrderTransactionData`` protobuf exactly (camelCase).\nAll fields are optional because protobuf objects may omit any attribute.",
        "properties": {
          "id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Id"
          },
          "orderId": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Orderid"
          },
          "account": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Account"
          },
          "symbol": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Symbol"
          },
          "identifier": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Identifier"
          },
          "multiplier": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Multiplier"
          },
          "action": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Action"
          },
          "market": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Market"
          },
          "currency": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Currency"
          },
          "segType": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Segtype"
          },
          "secType": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Sectype"
          },
          "filledPrice": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Filledprice"
          },
          "filledQuantity": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Filledquantity"
          },
          "createTime": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Createtime"
          },
          "updateTime": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Updatetime"
          },
          "transactTime": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Transacttime"
          },
          "timestamp": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Timestamp"
          }
        },
        "title": "TransactionPayload",
        "type": "object"
      },
      "description": "JSON-encoded transaction payload.",
      "title": "Payload",
      "type": "string"
    }
  },
  "required": [
    "account",
    "received_at",
    "payload"
  ],
  "title": "TransactionEvent",
  "type": "object"
}

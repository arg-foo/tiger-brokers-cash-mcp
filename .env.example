# Tiger Brokers API Credentials
TIGER_ID=your_tiger_id
TIGER_ACCOUNT=your_account_number
TIGER_PRIVATE_KEY_PATH=/path/to/private.pem

# Trading Limits (0 = no limit)
TIGER_MAX_ORDER_VALUE=0
TIGER_DAILY_LOSS_LIMIT=0
TIGER_MAX_POSITION_PCT=0

# MCP Transport (stdio or streamable-http)
MCP_TRANSPORT=stdio
MCP_HOST=0.0.0.0
MCP_PORT=8000
# Comma-separated allowed Host header values for DNS rebinding protection.
# Leave empty to auto-detect from MCP_HOST (recommended for local dev).
# WARNING: When MCP_HOST=0.0.0.0 and this is empty, only loopback clients
# (localhost/127.0.0.1/::1) are accepted. Set this for external access.
MCP_ALLOWED_HOSTS=

# Docker: host port for Redis (container always listens on 6379 internally)
REDIS_PORT=6379

# Event Subscription (Tiger PushClient -> Redis Streams)
# In Docker, REDIS_URL is overridden to redis://redis:6379/0 automatically.
# For local dev, set this to match your Redis instance (e.g. redis://localhost:6379/0).
TIGER_EVENTS_ENABLED=false
REDIS_URL=redis://localhost:6379/0
REDIS_STREAM_PREFIX=tiger:events
REDIS_STREAM_MAXLEN=10000
TIGER_PUSH_RECONNECT_MAX_ATTEMPTS=200
TIGER_PUSH_RECONNECT_BASE_DELAY=1.0

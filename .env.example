# Tiger Brokers API Credentials
TIGER_ID=your_tiger_id
TIGER_ACCOUNT=your_account_number
TIGER_PRIVATE_KEY_PATH=/path/to/private.pem

# Trading Limits (0 = no limit)
TIGER_MAX_ORDER_VALUE=0
TIGER_DAILY_LOSS_LIMIT=0
TIGER_MAX_POSITION_PCT=0

# MCP Transport (stdio or streamable-http)
MCP_TRANSPORT=stdio
MCP_HOST=0.0.0.0
MCP_PORT=8000

# Event Subscription (Tiger PushClient -> Redis Streams)
TIGER_EVENTS_ENABLED=false
REDIS_URL=redis://localhost:6379/0
REDIS_STREAM_PREFIX=tiger:events
REDIS_STREAM_MAXLEN=10000
TIGER_PUSH_RECONNECT_MAX_ATTEMPTS=200
TIGER_PUSH_RECONNECT_BASE_DELAY=1.0
